# ─── Dependencies ───────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ─── Environment ────────────────────────
.env
.env.local
.env.*.local

# ─── Build output ───────────────────────
backend/dist/
frontend/dist/

# ─── SSL certificates (generate your own) ─
certs/*.crt
certs/*.key
!certs/README.md

# ─── IDE / Editor ──────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS files ──────────────────────────
.DS_Store
Thumbs.db
*.log

# ─── Docker volumes (created at runtime) ─
pgdata/
miniodata/

# ─── Prisma (generated client) ────────
backend/node_modules/.prisma/
backend/node_modules/@prisma/client/

# ─── npm / yarn / pnpm ───────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
