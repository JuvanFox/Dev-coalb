# ─── Database ───────────────────────
DB_USER=devcollab
DB_PASSWORD=devcollab_secret
DB_NAME=devcollab

# ─── MinIO (S3-compatible storage) ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_BUCKET=devcollab-files

# ─── Auth ───────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-in-production

# ─── GitHub OAuth (optional) ────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── App ────────────────────────────
NODE_ENV=production
FRONTEND_URL=https://192.168.10.122:3000

# ─── WebRTC / Mediasoup ────────────
ANNOUNCED_IP=192.168.10.122

# ─── Client env (built at build time) ─
# Leave empty when using frontend nginx reverse proxy (recommended)
VITE_API_URL=
VITE_WS_URL=
